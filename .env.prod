# Production — on the server: docker run --env-file /path/to/.env.prod ...
# Set bucket and URIs; leave AWS keys empty on EC2 if you use an IAM role.

SPRING_ELASTICSEARCH_URIS=http://10.101.0.88:9200
SPRING_ELASTICSEARCH_CONNECTION_TIMEOUT=10s
SPRING_ELASTICSEARCH_SOCKET_TIMEOUT=60s

AWS_S3_BUCKET=your-prod-bucket
AWS_S3_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
