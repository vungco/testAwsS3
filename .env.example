# Sao chép thành file .env và điền giá trị thật:
#   cp .env.example .env
#
# File .env đã được .gitignore — không commit secret.
#
# Chạy app: ./gradlew bootRun (Gradle tự đọc .env và inject vào process)
# Hoặc tay: set -a && source .env && set +a && ./gradlew bootRun

# S3 — bắt buộc điền bucket (region mặc định ap-southeast-1 nếu bỏ trống trong .env nhưng nên set rõ)
AWS_S3_BUCKET=
AWS_S3_REGION=ap-southeast-1

# IAM access key (để trống nếu dùng ~/.aws/credentials hoặc IAM role)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Chỉ khi dùng credential tạm (STS, assume role) — có thể bỏ trống
# AWS_SESSION_TOKEN=
