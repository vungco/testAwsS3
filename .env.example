# Copy to .env.dev or .env.prod and fill in values.
#
# Local: ./gradlew bootRun              (loads .env.dev by default)
# ./gradlew bootRun -PenvFile=.env.prod
#
# Docker: docker run --env-file .env.prod ...

SPRING_ELASTICSEARCH_URIS=
SPRING_ELASTICSEARCH_CONNECTION_TIMEOUT=10s
SPRING_ELASTICSEARCH_SOCKET_TIMEOUT=60s

AWS_S3_BUCKET=
AWS_S3_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
